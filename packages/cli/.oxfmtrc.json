{
  "$schema": "../../node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "trailingComma": "all",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "quoteProps": "as-needed",
  "proseWrap": "preserve",
  "htmlWhitespaceSensitivity": "css",
  "embeddedLanguageFormatting": "auto",
  "insertFinalNewline": true,
  "sortPackageJson": false,
  "ignorePatterns": [
    "pnpm-lock.yaml",
    "README.md",
    "**/*.json",
    ".github/",
    "dist/",
    "node_modules/",
    "coverage/",
    "out/",
    ".cache/",
    "*.tgz",
    ".browserbase/",
    ".browserbase/**",
    "**/.browserbase/",
    "**/.browserbase/**"
  ]
}
