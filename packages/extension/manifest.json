{
  "manifest_version": 3,
  "name": "Stagehand",
  "version": "0.1.0",
  "description": "Control browser tabs with AI via Stagehand - act, observe, extract, and agent execute on any page.",
  "permissions": [
    "debugger",
    "tabs",
    "activeTab",
    "sidePanel",
    "storage"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open Stagehand",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
