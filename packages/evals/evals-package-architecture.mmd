%% =============================================================
%% Stagehand Evals · package architecture
%%
%% Layered top-down by execution phase:
%%   1. Entrypoints   — user surface + builds
%%   2. TUI           — command dispatch
%%   3. Registry      — task discovery
%%   4. Planning      — matrix expansion
%%   5. Runner        — orchestration + telemetry
%%   6. Core / Bench  — parallel execution tiers
%%   7. Reporting     — outputs / inspection
%%   8. External      — third-party services
%%
%% Shape conventions:
%%   ([ stadium ])   — process / module
%%   [( cylinder )]  — data store / config / dataset
%%   {{ hexagon }}   — external service
%%
%% Edge conventions:
%%   ==>             — hot run path
%%   -.->            — lazy / on-demand load
%%   --|label|-->    — labeled relationship
%% =============================================================
flowchart TB

    %% --- 1. Entrypoints ---------------------------------------
    subgraph Entrypoints["1 · Entrypoints &amp; Distribution"]
        direction TB
        CLI(["cli.ts<br/>argv single-shot"])
        REPL(["tui/repl.ts<br/>interactive · Esc abort"])
        BuildCLI(["scripts/build-cli.ts<br/>bundled dist/cli"])
        BuildESM(["scripts/build-esm.ts<br/>dist/esm + datasets"])
        LegacyCLI(["cli-legacy.ts · index.eval.ts<br/>--legacy escape hatch"])
        LegacyRunner(["pre-refactor runner"])
    end

    %% --- 2. TUI ------------------------------------------------
    subgraph TUI["2 · TUI Command Layer"]
        direction TB
        Help(["help"])
        List(["list<br/>registry views"])
        ConfigCmd(["config<br/>defaults · core tool"])
        NewTask(["new<br/>scaffold task"])
        Experiments(["experiments<br/>Braintrust inspect &amp; compare"])
        RunCmd(["run<br/>progress · dry-run plan"])
        Parse(["parse.ts<br/>flags · shorthand · env scope"])
        ConfigFile[("evals.config.json<br/>defaults · core · benchmarks")]
    end

    %% --- 3. Registry & Resolution -----------------------------
    subgraph Registry["3 · Task Registry &amp; Resolution"]
        direction TB
        RuntimePaths(["runtimePaths.ts<br/>source vs dist roots"])
        Discovery(["framework/discovery.ts<br/>fs scan · category tags"])
        Resolver(["resolveTarget()<br/>tier · category · task"])
        DefineTask(["framework/defineTask.ts<br/>defineCoreTask · defineBenchTask"])
        CoreTasks[("core/tasks/*<br/>deterministic tool tasks")]
        BenchTasks[("tasks/bench/*<br/>act · extract · observe<br/>agent · combination · suites")]
    end

    %% --- 4. Planning ------------------------------------------
    subgraph Planning["4 · Run Planning"]
        direction TB
        ResolvedOptions(["ResolvedRunOptions<br/>env · trials · concurrency<br/>model · provider · api<br/>harness · agentMode"])
        BenchPlanner(["framework/benchPlanner.ts<br/>matrix · suite expansion · tags"])
        TaskConfig(["taskConfig.ts<br/>default models · agent entries"])
        DryRun(["--dry-run JSON<br/>tasks · env · runOptions"])
        Datasets[("datasets/*<br/>WebVoyager · OnlineMind2Web<br/>WebTailBench")]
    end

    %% --- 5. Runner --------------------------------------------
    subgraph Runner["5 · Unified Runner"]
        direction TB
        RunEvals(["framework/runner.ts<br/>testcases · Braintrust Eval<br/>progress callbacks"])
        BraintrustAdapter(["framework/braintrust.ts<br/>lazy import · traced spans"])
        Cleanup(["activeRunCleanup.ts<br/>signal cleanup · session refs"])
        Scoring(["scoring.ts<br/>passRate · exactMatch · errorMatch"])
        Summary(["summary.ts<br/>local run summary"])
    end

    %% --- 6a. Core Tier ----------------------------------------
    subgraph CoreTier["6a · Core Tier Execution"]
        direction TB
        CoreContext(["framework/context.ts<br/>buildCoreContext()"])
        FixtureServer(["core/fixtures<br/>local deterministic pages"])
        CoreTargets(["core/targets<br/>local Chrome · Browserbase CDP"])
        CoreTools(["core/tools registry<br/>understudy · playwright · cdp<br/>MCP · browse_cli"])
        CoreAssertions(["assertions + metrics<br/>adapter-backed results"])
    end

    %% --- 6b. Bench Tier ---------------------------------------
    subgraph BenchTier["6b · Bench Tier Execution"]
        direction TB
        BenchRunner(["framework/benchRunner.ts<br/>load · execute bench task"])
        TaskLoader(["framework/taskLoader.ts<br/>defineBenchTask + legacy"])
        HarnessRegistry(["framework/benchHarness.ts<br/>stagehand · claude_code<br/>(codex pending)"])
        InitV3(["initV3.ts<br/>V3 session + agent"])
        AISDK(["AISdkClientWrapped<br/>provider/model client"])
        ClaudeCodeRunner(["framework/claudeCodeRunner.ts<br/>SDK adapter · prompt &amp; parse"])
        ClaudeCodeToolAdapter(["framework/claudeCodeToolAdapter.ts<br/>tool-surface handoff<br/>browse_cli wrapper"])
        ExternalHarnessPlan(["framework/externalHarnessPlan.ts<br/>webvoyager · onlineMind2Web<br/>webtailbench task plan"])
        BenchSuites(["suites/*<br/>dataset-backed cases"])
        BenchTaskDefs(["bench task modules<br/>defineBenchTask · legacy fn"])
    end

    %% --- 7. Reporting -----------------------------------------
    subgraph Reporting["7 · Reporting &amp; Inspection"]
        direction TB
        Progress(["tui/progress.ts<br/>live task table"])
        ResultsView(["tui/results.ts<br/>model summary · results table"])
        ReportLib(["lib/braintrust-report.ts<br/>experiment fetch · compare"])
        RenderReport(["scripts/render-braintrust-core-report.ts<br/>core report rendering"])
    end

    %% --- 8. External -------------------------------------------
    subgraph External["8 · External Systems"]
        direction TB
        Braintrust{{"Braintrust<br/>experiments · spans · scores"}}
        Browserbase{{"Browserbase<br/>remote browser sessions"}}
        LocalBrowser{{"Local Chromium<br/>fixture-backed sessions"}}
        Providers{{"LLM Providers<br/>OpenAI · Anthropic · Google"}}
        Stagehand{{"Stagehand package<br/>V3 · AgentProvider · models"}}
        ClaudeCodeSDK{{"@anthropic-ai/claude-agent-sdk<br/>headless agent runtime"}}
    end

    %% =============================================================
    %% Edges
    %% =============================================================

    %% --- Entrypoints → TUI / Build
    CLI --> Parse
    CLI --> RunCmd
    CLI --> List
    CLI --> ConfigCmd
    CLI --> Experiments
    CLI --> NewTask
    CLI --> Help
    REPL --> Parse
    REPL --> RunCmd
    BuildCLI --> CLI
    BuildESM --> RuntimePaths
    LegacyCLI --> LegacyRunner

    %% --- TUI / config
    ConfigCmd <--> ConfigFile
    Parse --> ConfigFile
    Parse --> ResolvedOptions
    Parse --> DryRun
    RunCmd --> ResolvedOptions
    RunCmd --> RuntimePaths
    RunCmd --> Discovery
    List --> Discovery
    NewTask --> CoreTasks
    NewTask --> BenchTasks
    Experiments --> ReportLib

    %% --- Registry
    RuntimePaths --> CoreTasks
    RuntimePaths --> BenchTasks
    CoreTasks --> Discovery
    BenchTasks --> Discovery
    DefineTask --> CoreTasks
    DefineTask --> BenchTasks
    Discovery --> Resolver
    Resolver --> RunCmd

    %% --- Planning
    RunCmd --> BenchPlanner
    RunCmd --> DryRun
    ResolvedOptions --> BenchPlanner
    TaskConfig --> BenchPlanner
    Datasets --> BenchSuites
    BenchSuites --> BenchPlanner
    BenchPlanner --> RunEvals
    Resolver --> RunEvals

    %% --- Runner (hot path)
    RunCmd ==> RunEvals
    RunEvals -.->|lazy| BraintrustAdapter
    RunEvals --> Cleanup
    RunEvals --> Scoring
    RunEvals --> Summary
    RunEvals --> CoreContext
    RunEvals --> BenchRunner
    RunEvals --> Progress
    Progress --> ResultsView

    %% --- Core path
    CoreContext --> FixtureServer
    CoreContext --> CoreTargets
    CoreContext --> CoreTools
    CoreContext --> CoreAssertions
    CoreTargets --> LocalBrowser
    CoreTargets --> Browserbase
    CoreTools --> LocalBrowser
    CoreTools --> Browserbase

    %% --- Bench (Stagehand harness)
    BenchRunner --> HarnessRegistry
    BenchRunner --> TaskLoader
    TaskLoader --> BenchTaskDefs
    HarnessRegistry --> InitV3
    InitV3 --> Stagehand
    InitV3 --> Browserbase
    InitV3 --> LocalBrowser
    HarnessRegistry --> AISDK
    AISDK --> Providers
    BenchRunner --> BenchTaskDefs
    BenchTaskDefs --> Stagehand
    BenchSuites --> Datasets

    %% --- Bench (Claude Code external harness)
    HarnessRegistry --> ClaudeCodeRunner
    HarnessRegistry --> ClaudeCodeToolAdapter
    HarnessRegistry --> ExternalHarnessPlan
    ClaudeCodeToolAdapter --> CoreTools
    ClaudeCodeToolAdapter --> CoreTargets
    ClaudeCodeRunner --> ClaudeCodeSDK
    ClaudeCodeSDK --> Providers

    %% --- Reporting / external
    BraintrustAdapter --> Braintrust
    ReportLib --> Braintrust
    RenderReport --> ReportLib
    Summary --> Braintrust
    Stagehand --> Providers

