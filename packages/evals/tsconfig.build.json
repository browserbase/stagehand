  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "declaration": true,
    "inlineSources": true,
    "noEmit": false,
    "outDir": "dist/esm",
    "rootDir": ".",
    "sourceMap": true
  },
  "exclude": [
    "cli.ts",
    "dist",
