{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "trailingComma": "all",
  "bracketSpacing": true,
  "bracketSameLine": false,
  "arrowParens": "always",
  "endOfLine": "lf",
  "quoteProps": "as-needed",
  "proseWrap": "preserve",
  "htmlWhitespaceSensitivity": "css",
  "embeddedLanguageFormatting": "auto",
  "insertFinalNewline": true,
  "sortPackageJson": false,
  "ignorePatterns": [
    "pnpm-lock.yaml",
    "README.md",
    "**/*.json",
    "docs/",
    ".github/",
    "dist/",
    "node_modules/",
    "lib/dom/build/",
    "lib/v3/dom/build/",
    "packages/core/dist/",
    "packages/core/lib/dom/build/",
    "packages/core/lib/v3/dom/build/",
    "packages/cli/dist/",
    "packages/evals/dist/",
    "packages/docs/",
    "*.min.js",
    ".browserbase/",
    ".browserbase/**",
    "**/.browserbase/",
    "**/.browserbase/**",
    "stainless.yml",
    "openapi.*.yaml"
  ]
}
