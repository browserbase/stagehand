OPENAI_API_KEY=""
CEREBRAS_API_KEY=""
GROQ_API_KEY=""
BROWSERBASE_API_KEY=""
BRAINTRUST_API_KEY=""
ANTHROPIC_API_KEY=""
HEADLESS=false
ENABLE_CACHING=false
EVAL_MODELS="gpt-4o,claude-sonnet-4-6"
EXPERIMENTAL_EVAL_MODELS="gpt-4o,claude-sonnet-4-6,o1-mini,o1-preview"
EVAL_CATEGORIES="observe,act,combination,extract,experimental"
AGENT_EVAL_MAX_STEPS=50

# --- Experiment tracing / backends ------------------------------------------
# Evals can push results to an experiment backend. Configure at least one of
# Braintrust (BRAINTRUST_API_KEY, above) or LangSmith below; the doctor warns
# when neither is set.
#
# LangSmith API key. Configure this and set LANGSMITH_TRACING="true" to emit traces.
LANGSMITH_API_KEY=""
# Master switch for LangSmith tracing ("true" to emit traces).
LANGSMITH_TRACING="false"
# Trace transport: how spans are shipped ("native" | "otel").
EVAL_TRACE_TRANSPORT="native"
# Optional Braintrust OTEL parent override (defaults to project_name:stagehand-dev,
# or project_name:stagehand in CI).
# BRAINTRUST_OTEL_PARENT="project_name:stagehand-dev"
# Optional Braintrust OTEL traces endpoint override.
# BRAINTRUST_OTEL_URL="https://api.braintrust.dev/otel/v1/traces"
# Primary trace sink when multiple are configured ("braintrust" | "langsmith").
EVAL_TRACE_PRIMARY="braintrust"
